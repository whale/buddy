.DS_Store
.screenshots/
node_modules/
*.log
.playwright-mcp/

# skill-manager artifacts (skill is installed globally, not vendored here)
skills-lock.json
.agents/

# Tauri / Rust build artifacts (Phase C Mac shell)
src-tauri/target/
src-tauri/gen/
pnpm-lock.yaml

# Apple signing / notarization creds — never commit
.env

# Cross-platform icons emitted by `tauri icon` that this Mac-only app doesn't use
src-tauri/icons/Square*Logo.png
src-tauri/icons/StoreLogo.png
src-tauri/icons/icon.ico
src-tauri/icons/ios/
src-tauri/icons/android/

# Playwright run artifacts
test-results/
.supabase-buddy.secret

# iOS build output + fastlane run artifacts
ios/build/
ios/fastlane/report.xml
ios/fastlane/README.md

# App Store Connect private keys — never commit
*.p8
AuthKey_*

# Buddy Cloud config — present ONLY in hosted builds (CI injects it from a secret).
# A clone runs local-only without it: that IS the open-source edition.
dist/config.js

# Claude session plumbing — machine-local symlinks + worktree state, never shared
# (.claude/skills symlinks into ~/Projects/.agents — dangles on any other machine)
.claude/
