# Buddy iOS — TestFlight delivery.
#
# `fastlane beta` builds a Release archive and uploads it to TestFlight.
# Auth is via an App Store Connect API key (no Apple ID / 2FA), read from
# env vars so no secret ever lives in the repo:
#   ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_PATH (path to the .p8 file).
#
# Signing is Automatic (set in project.yml); `-allowProvisioningUpdates`
# lets Xcode create/refresh the distribution profile using the API key.
# The build number is computed from git history and passed as a build
# setting so it survives xcodegen regeneration.

default_platform(:ios)

PROJECT = "Buddy.xcodeproj"
SCHEME  = "Buddy"
APP_ID  = "fyi.whale.buddy"

platform :ios do
  desc "Build and upload a new build to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
      in_house: false
    )

    next_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: APP_ID,
      initial_build_number: 0
    ).to_i + 1

    # The .xcodeproj is generated from project.yml — regenerate before building.
    sh("cd .. && xcodegen generate")

    build_app(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates CURRENT_PROJECT_VERSION=#{next_build}",
      output_directory: "build",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
