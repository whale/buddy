# Buddy iOS — TestFlight delivery.
#
# `fastlane beta` builds a Release archive and uploads it to TestFlight.
# Auth is via an App Store Connect API key (no Apple ID / 2FA), read from
# env vars so no secret ever lives in the repo:
#   ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_PATH (path to the .p8 file).
#
# Signing is Automatic (set in project.yml); `-allowProvisioningUpdates`
# lets Xcode create/refresh the distribution profile using the API key.
# The build number is computed from git history and passed as a build
# setting so it survives xcodegen regeneration.

default_platform(:ios)

PROJECT = "Buddy.xcodeproj"
SCHEME  = "Buddy"
APP_ID  = "fyi.whale.buddy"

platform :ios do
  desc "Build and upload a new build to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
      in_house: false
    )

    next_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: APP_ID,
      initial_build_number: 0
    ).to_i + 1

    # The .xcodeproj is generated from project.yml — regenerate before building.
    sh("cd .. && xcodegen generate")

    # Buddy Cloud config — THE hosted/open split (mirror of dist/config.js on Mac).
    # The TestFlight/App Store build IS the hosted edition: overwrite the tracked
    # nil-valued BuddyCloud.swift with the real url + publishable key from the env
    # (~/.config/secrets.env), build, then ALWAYS restore the tracked file so real
    # values are never committed. A clone without the env vars builds the open
    # edition unchanged.
    cloud_url  = ENV["BUDDY_CLOUD_URL"]
    cloud_anon = ENV["BUDDY_CLOUD_ANON_KEY"]
    cloud_file = File.expand_path("../Buddy/Sources/Sync/BuddyCloud.swift", __dir__)
    if cloud_url.to_s.empty? || cloud_anon.to_s.empty?
      UI.important("No BUDDY_CLOUD_* env — building the OPEN edition (local-only sync UI).")
    else
      UI.message("Hosted build: injecting Buddy Cloud config.")
      File.write(cloud_file, <<~SWIFT)
        import Foundation

        // GENERATED BY FASTLANE FOR A HOSTED BUILD — never commit real values.
        // Publishable identifiers, not secrets; enforcement is server-side.
        enum BuddyCloud {
            static let url: String? = #{cloud_url.inspect}
            static let anon: String? = #{cloud_anon.inspect}

            static var present: Bool {
                !(url ?? "").isEmpty && !(anon ?? "").isEmpty
            }
        }
      SWIFT
    end

    begin
      build_app(
        project: PROJECT,
        scheme: SCHEME,
        configuration: "Release",
        export_method: "app-store",
        xcargs: "-allowProvisioningUpdates CURRENT_PROJECT_VERSION=#{next_build}",
        output_directory: "build",
        clean: true
      )
    ensure
      # Restore the tracked nil-valued file even if the build throws.
      sh("cd .. && git checkout -- Buddy/Sources/Sync/BuddyCloud.swift") unless cloud_url.to_s.empty?
    end

    # WAIT for processing. "Uploaded" only means the transporter accepted the
    # payload — ingestion can still silently drop the build (it then never
    # appears in TestFlight and only the account holder gets an email). With
    # waiting on, a green `fastlane beta` means the build is genuinely visible
    # to testers; a swallowed build fails the lane instead (field report
    # 2026-07-10: "you say it's pushed and I don't see anything").
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: false,
      distribute_external: false,
      notify_external_testers: false
    )
  end

  desc "Show the latest TestFlight builds with their REAL visibility state. " \
       "'Uploaded' ≠ 'visible': a build only reaches the TestFlight app once " \
       "processing finishes AND internal state is IN_BETA_TESTING. Run this " \
       "whenever a build 'doesn't show up'."
  lane :status do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
      in_house: false
    )
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.from(hash: api_key)
    app = Spaceship::ConnectAPI::App.find(APP_ID)
    builds = app.get_builds(includes: "buildBetaDetail,preReleaseVersion",
                            sort: "-uploadedDate", limit: 5)
    builds.each do |b|
      d = b.build_beta_detail
      UI.important("build #{b.version} (v#{b.pre_release_version&.version}) " \
        "uploaded #{b.uploaded_date} | processing: #{b.processing_state} | " \
        "internal: #{d&.internal_build_state} | external: #{d&.external_build_state}")
    end
  end
end
